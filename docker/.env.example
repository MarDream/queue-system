# ============================
# 排队叫号系统 - 环境变量配置
# 复制此文件为 .env 并修改
# ============================

# ---- 外部 MySQL ----
MYSQL_HOST=43.155.249.87
MYSQL_PORT=3306
MYSQL_USERNAME=root
MYSQL_PASSWORD=3edc$RFV

# ---- 外部 Redis ----
REDIS_HOST=43.155.249.87
REDIS_PORT=6379
REDIS_PASSWORD=3edc$RFV

# ---- 后端 ----
JWT_SECRET=change-me-in-production-must-be-at-least-32-chars!

# ---- 前端 (Nginx) ----
FRONTEND_PORT=80

# ---- 应用 IP（必须设为外部可达的 IP 或域名，用于二维码生成、CORS 等）----
# 留空则容器内自动检测（通常不准确，建议填写）
APP_IP=43.155.249.87

# ---- CORS 额外允许源（逗号分隔，可选）----
# 例如: http://192.168.1.100,http://queue.example.com
APP_CORS_ORIGINS=
